# Default OBJ for alice2 zSpace halfedge traversal sketch.
# Four quads with shared interior edges, useful for next/prev/sym traversal.
v -1.0 -1.0 0.0
v  0.0 -1.0 0.0
v  1.0 -1.0 0.0
v -1.0  0.0 0.0
v  0.0  0.0 0.0
v  1.0  0.0 0.0
v -1.0  1.0 0.0
v  0.0  1.0 0.0
v  1.0  1.0 0.0
f 1 2 5 4
f 2 3 6 5
f 4 5 8 7
f 5 6 9 8
